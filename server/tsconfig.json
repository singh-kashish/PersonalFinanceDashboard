{
  "compilerOptions": {
    "target": "ES2020",

    "module": "commonjs",

    "types": ["node"],

    "rootDir": "./src",
    "outDir": "./dist",

    "sourceMap": true,

    "strict": true,

    "esModuleInterop": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "skipLibCheck": true
  },

  "include": ["src"]
}